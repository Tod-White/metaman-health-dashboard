* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --bg: #f5f7fb;
    --card: #ffffff;
    --border: #e7ebf3;
    --text: #1f2937;
    --muted: #667085;
    --primary: #4453a6;
    --primary-soft: #eef2ff;
    --success: #4caf50;
    --warning: #ff9800;
    --shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
    --radius: 10px;
    --gap: 10px;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    min-height: 100vh;
    padding: 10px;
    color: var(--text);
    font-size: 13px;
}

.container {
    max-width: 1320px;
    margin: 0 auto;
}

header {
    margin-bottom: 20px;
    padding: 0 2px;
}

header h1 {
    font-size: 1.3rem;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 2px;
}

.subtitle {
    font-size: 0.8rem;
    color: var(--muted);
}

.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 12px;
    min-width: 0;
}

.compact-card {
    padding: 12px;
}

.hero-chart-section {
    margin-bottom: 10px;
}

.full-hero-chart {
    display: flex;
    flex-direction: column;
}

.hero-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
}

.hero-chart-section h2,
.analysis-section h2,
.today-section h2 {
    font-size: 0.98rem;
    line-height: 1.2;
    color: var(--primary);
    margin-bottom: 8px;
}

.chart-section {
    box-shadow: 0 8px 32px rgba(59, 130, 246, 0.15), 0 2px 8px rgba(139, 92, 246, 0.1);
    border-radius: 20px;
    background: linear-gradient(135deg, #eff6ff 0%, #e0e7ff 30%, #dbeafe 60%, #e0f2fe 100%);
    border: 1px solid rgba(99, 102, 241, 0.2);
    display: flex;
    flex-direction: column;
}

.chart-section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 50%, #0ea5e9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
}

.title-with-date {
    display: flex;
    align-items: baseline;
    gap: 10px;
}

.current-date {
    font-size: 0.75rem;
    color: #0ea5e9;
    font-weight: 600;
    opacity: 0.7;
    letter-spacing: 0.3px;
}

.hero-subtitle {
    margin-top: 2px;
    font-size: 0.76rem;
    color: var(--muted);
}

.range-tabs {
    display: inline-flex;
    gap: 6px;
    flex-shrink: 0;
}

.range-tab {
    border: 1px solid rgba(59, 130, 246, 0.25);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    color: #2563eb;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
}

.range-tab:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.2);
}

.range-tab.active {
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 50%, #0ea5e9 100%);
    border-color: transparent;
    color: white;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
}

.chart-container {
    position: relative;
    width: 100%;
    height: 360px;
}

.chart-container canvas,
.full-hero-chart canvas {
    width: 100% !important;
    height: 100% !important;
    max-height: none;
}

.chart-inline-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    align-items: center;
    margin-top: 10px;
    padding-top: 2px;
}

.chart-inline-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.78rem;
    color: var(--muted);
}

.chart-inline-line {
    width: 18px;
    height: 0;
    border-top: 3px solid currentColor;
    border-radius: 999px;
    display: inline-block;
}

.chart-inline-line-green {
    color: #10b981;
}

.chart-inline-line-red {
    color: #ef4444;
}

.chart-inline-line-blue {
    color: #3b82f6;
}

.daily-title {
    font-size: 1.15rem;
    font-weight: 700;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 50%, #0ea5e9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 12px 0 10px 0;
    padding: 0 4px;
    line-height: 1.4;
}

.daily-observation {
    background: transparent;
    border-radius: 12px;
    padding: 0;
    margin-bottom: 0;
    box-shadow: none;
    border: none;
}

.observation-card .daily-observation {
    margin-bottom: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
}

.observation-content {
    font-size: 1rem;
    line-height: 1.5;
    color: #4f46e5;
    font-weight: 500;
}

.daily-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 8px;
    line-height: 1.4;
}

.observation-card {
    background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 50%, #c7d2fe 100%);
    border-radius: 16px;
    padding: 16px 20px 16px 20px;
    margin-bottom: 24px;
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.25);
    border: 2px solid transparent;
    background-clip: padding-box;
    position: relative;
}

.observation-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 16px;
    padding: 3px;
    background: linear-gradient(135deg, #a78bfa, #818cf8, #60a5fa);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.8;
}

.observation-card .daily-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 16px;
}

.observation-card .title-main {
    font-size: 1.5rem;
    font-weight: 700;
    color: #6366f1;
    margin-bottom: 4px;
}

.observation-card .title-subtitle {
    font-size: 1.25rem;
    font-weight: 600;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 50%, #0ea5e9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.observation-card .daily-observation {
    margin-bottom: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
}

.metrics-legend,
.compact-legend {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px 10px;
    margin-top: 8px;
}

.metric {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
    font-size: 0.74rem;
    color: var(--muted);
}

.metric .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: 0 0 auto;
}

.metric span:last-child {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.tighter-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 10px;
    align-items: start;
    margin-top: 24px;
}

.body-diagram-container {
    margin-bottom: 10px;
    border-radius: 8px;
    overflow: hidden;
    background: #f8faff;
    border: 1px solid #dde3ef;
}

.body-diagram-img {
    width: 100%;
    height: auto;
    display: block;
}

.summary-box {
    border: 1px solid #dde3ef;
    border-radius: 8px;
    background: #f8faff;
    padding: 10px 11px;
    display: grid;
    gap: 8px;
}

.summary-box p {
    font-size: 0.79rem;
    line-height: 1.45;
    color: var(--text);
}

.section-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
}

.chart-section > .section-title-row {
    margin-bottom: 0;
}

.chart-section > .range-tabs {
    align-self: flex-end;
    margin-bottom: 8px;
}

.section-title-row h2 {
    margin-bottom: 0;
}

.task-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.detailed-task {
    border: 1px solid #e9edf6;
    border-radius: 10px;
    overflow: hidden;
    background: #fbfcfe;
}

.task-head {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 72px;
    gap: 8px;
    align-items: center;
    padding: 8px 10px;
    border-bottom: 1px solid #edf1f7;
    background: #f7f8fc;
}

.task-head .time {
    font-weight: 700;
    color: var(--primary);
}

.task-head .name {
    font-weight: 600;
    font-size: 0.82rem;
}

.task-head .duration {
    text-align: right;
    font-size: 0.72rem;
    color: var(--muted);
}

.task-steps {
    padding: 8px 14px 10px 24px;
    display: grid;
    gap: 4px;
}

.task-steps li {
    font-size: 0.76rem;
    line-height: 1.4;
    color: var(--text);
}

details.task {
    overflow: hidden;
}

details.task summary {
    list-style: none;
    cursor: pointer;
}

details.task summary::-webkit-details-marker {
    display: none;
}

details.task .task-head::after {
    content: '▾';
    color: var(--muted);
    font-size: 0.82rem;
    justify-self: end;
}

details.task:not([open]) .task-head::after {
    content: '▸';
}

@media (max-width: 1080px) {
    .tighter-layout {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    body {
        padding: 8px;
    }

    .hero-header {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }

    .hero-header > div:first-child {
        width: 100%;
    }

    .hero-chart-section h2 {
        font-size: 0.92rem;
        line-height: 1.3;
        margin-bottom: 4px;
    }

    .section-title-row {
        flex-direction: column;
        align-items: flex-start;
    }

    .chart-section {
        display: flex;
        flex-direction: column;
    }
    
    .chart-section > .section-title-row {
        order: 1;
    }

    .chart-section > .daily-title {
        order: 2;
    }

    .chart-section > .daily-observation {
        order: 3;
    }

    .chart-section > .range-tabs {
        order: 4;
        align-self: stretch;
        margin-bottom: 12px;
    }

    .chart-section > .chart-container {
        order: 5;
    }
    
    .chart-section > .chart-inline-legend {
        order: 6;
    }

    .range-tabs {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-bottom: 14px;
    }

    .range-tab {
        width: 100%;
        min-width: 0;
        text-align: center;
        padding: 7px 0;
        font-size: 0.78rem;
    }

    .metrics-legend,
    .compact-legend {
        grid-template-columns: 1fr;
    }

    .chart-container {
        height: 218px;
    }

    .task-head {
        grid-template-columns: 50px minmax(0, 1fr) 62px;
    }

    .observation-content {
        font-size: 0.875rem;
    }

    .observation-card {
        padding: 10px 13px;
        margin-bottom: 14px;
    }
}
